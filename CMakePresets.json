{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-default",
      "displayName": "VS2022 Default (Bots + Extractors)",
      "description": "Default local Windows preset with extractors, playerbots and ahbot enabled.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/../CmangosWotlkBuild-preset",
      "cacheVariables": {
        "BUILD_GAME_SERVER": "ON",
        "BUILD_LOGIN_SERVER": "ON",
        "BUILD_EXTRACTORS": "ON",
        "BUILD_PLAYERBOTS": "ON",
        "BUILD_AHBOT": "ON",
        "BUILD_DEPRECATED_PLAYERBOT": "OFF",
        "DEV_BINARY_DIR": "${sourceDir}/../CmangosWotlkBuild-preset",
        "LOCAL_ZLIB_SOURCE_DIR": "${sourceDir}/dep/src/zlib-1.3.1"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-relwithdebinfo",
      "displayName": "Build RelWithDebInfo",
      "configurePreset": "vs2022-default",
      "configuration": "RelWithDebInfo"
    }
  ]
}
